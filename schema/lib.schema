;; meta-signal-agent — meta policy wire contract for the `agent` LLM-call component.
;;
;; Wire-only: schema-emitted Input/Output roots + rkyv + optional NOTA codec on the
;; signal-frame envelope. Mutating authority lives HERE, not in the ordinary signal-agent
;; contract. Runtime, the provider registry, sockets, and storage live in the `agent` daemon.
;;
;; This is the security-sensitive door: only the component's owner (the deploy/bootstrap tool
;; or the gated-Spirit owner) configures providers and drives lifecycle through this contract.
;;
;; PROVIDER MODEL (psyche f8k7): a provider is a GENERIC OpenAI-compatible API — endpoint URL,
;; default model, and a typed secret-source reference the daemon resolves, never the secret value
;; itself. Adding DeepSeek, MiMo, Kimi, GLM, or MiniMax is a ConfigureProvider message,
;; never a contract change. DeepSeek and MiMo are the first two configured providers.

{}

[(ConfigureProvider ConfigureProvider)
 (RetireProvider RetireProvider)
 (SetDefaultProvider SetDefaultProvider)
 (Start Start)
 (Stop Stop)]
[(ProviderConfigured ProviderConfigured)
 (ProviderRetired ProviderRetired)
 (DefaultProviderSet DefaultProviderSet)
 (Started Lifecycle)
 (Stopped Lifecycle)
 (OrderRejected OrderRejection)
 (RequestUnimplemented RequestUnimplemented)]
{
  ProviderName { value String }
  EndpointUrl { value String }
  ModelName { value String }
  EnvironmentVariable { value String }
  GopassPath { value String }
  SecretFilePath { value String }
  RejectionDetail { value String }

  ;; The API-key source reference. The secret value never crosses this wire; the
  ;; agent daemon resolves the source and holds the secret only for one provider
  ;; call. Gopass is a first-class backend, not a caller-side convention.
  EnvironmentSecret { variable EnvironmentVariable }
  GopassSecret { path GopassPath }
  FileSecret { path SecretFilePath }
  SecretSource [(Environment EnvironmentSecret) (Gopass GopassSecret) (File FileSecret)]

  ;; A provider is endpoint + default model + secret source. This IS the
  ;; "add a provider = pure configuration" record: no per-provider type.
  ProviderConfiguration {
    name ProviderName
    endpoint EndpointUrl
    default_model ModelName
    secret_source SecretSource
  }

  ConfigureProvider { configuration ProviderConfiguration }
  RetireProvider { name ProviderName }
  SetDefaultProvider { name ProviderName }
  Start { }
  Stop { }

  ProviderConfigured { name ProviderName }
  ProviderRetired { name ProviderName }
  DefaultProviderSet { name ProviderName }

  ;; Start and Stop share one lifecycle reply shape (component-triad reply
  ;; discipline: lifecycle-shaped verbs share an Action* pair).
  LifecycleState [Started Stopped]
  Lifecycle { state LifecycleState }

  OrderRejectionReason [
    ProviderUnknown
    ProviderAlreadyConfigured
    EndpointInvalid
    SecretUnavailable
    PolicyStoreUnavailable
  ]
  OrderRejection { reason OrderRejectionReason detail RejectionDetail }

  OperationKind [ConfigureProvider RetireProvider SetDefaultProvider Start Stop]
  UnimplementedReason [NotInPrototypeScope]
  RequestUnimplemented { operation OperationKind reason UnimplementedReason }
}
