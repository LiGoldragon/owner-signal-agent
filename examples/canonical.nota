;; Canonical NOTA examples for meta-signal-agent — the owner-only meta policy
;; contract for the `agent` LLM-call component.
;;
;; One example per request and reply variant, in the exact schema-derived wire
;; form (schema/lib.schema -> schema-rust-next -> generated Input / Output).
;; String delimiters are only for strings that need them. Mutating authority
;; (provider configuration, lifecycle) lives here, never in the ordinary
;; signal-agent contract.
;;
;; A provider = endpoint URL + default model + secret-source reference the
;; daemon resolves; the secret value never crosses the wire. Adding a provider
;; is a ConfigureProvider message — never a contract change. DeepSeek and MiMo
;; are the first two configured providers.

;; Requests
;;   ProviderConfiguration = (name  endpoint  default_model  secret_source)

(ConfigureProvider (deepseek https://api.deepseek.com/v1 deepseek-v4-flash (Gopass platform.deepseek.com/api-key)))
(ConfigureProvider (mimo https://api.mimo.example/v1 mimo-7b (Environment MIMO_API_KEY)))
(RetireProvider mimo)
(SetDefaultProvider deepseek)
(Start ())
(Stop ())

;; Replies

(ProviderConfigured deepseek)
(ProviderRetired mimo)
(DefaultProviderSet deepseek)
(Started Started)
(Stopped Stopped)
(OrderRejected (SecretUnavailable [secret source unavailable]))
(RequestUnimplemented (SetDefaultProvider NotInPrototypeScope))
